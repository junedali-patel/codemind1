{
  "name": "codemind-desktop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && node index.js",
    "build:client": "cd client && npm run build",
    "build": "npm run build:client && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.codemindai.app",
    "productName": "CodeMindAI",
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/.next/**/*",
      "client/public/**/*",
      "client/package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "server", "to": "server" }
    ],
    "win":   { "target": "nsis" },
    "mac":   { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}